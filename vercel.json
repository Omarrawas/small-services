{
  "version": 2,
  "builds": [
    {
      "src": "api/boot.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build/public" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/boot.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
